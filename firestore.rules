rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isVendorProductOwner() {
      return signedIn() &&
        resource.data.vendorId == request.auth.uid;
    }

    function isIncomingVendorProductOwner() {
      return signedIn() &&
        request.resource.data.vendorId == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || isIncomingVendorProductOwner();
      allow update, delete: if isAdmin() || isVendorProductOwner();
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow update, delete: if isAdmin();
    }

    match /platform_settings/{documentId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
