rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isVendor(vendorId) {
      return signedIn() && request.auth.uid == vendorId;
    }

    function isVendorProductOwner() {
      return signedIn() &&
        resource.data.vendorId == request.auth.uid;
    }

    function isIncomingVendorProductOwner() {
      return signedIn() &&
        request.resource.data.vendorId == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /vendors/{vendorId} {
      allow read: if isAdmin() || isVendor(vendorId);
      allow create: if isAdmin() || isVendor(vendorId);
      allow update: if isAdmin() || isVendor(vendorId);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || isIncomingVendorProductOwner();
      allow update, delete: if isAdmin() || isVendorProductOwner();

      // Product reviews subcollection
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if signedIn();
        allow update, delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || isVendor(resource.data.vendorId);
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.vendorId == request.auth.uid
          && request.resource.data.vendorId == resource.data.vendorId
          && request.resource.data.userId == resource.data.userId
        );
      allow delete: if isAdmin();
    }

    match /platform_settings/{documentId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
